# YoLink API credentials (optional)
# If omitted, all YoLink features are automatically disabled (no polling, widgets show nothing).
# Get these from: YoLink App → Account → Advanced Settings → Personal Access Credentials
YOLINK_UAID=your_uaid_here
YOLINK_SECRET=your_secret_key_here

# Path to health.sh output file (optional — defaults to /home/brian/health.txt)
# Set up a root cron to refresh it: * * * * * cd /home/brian && bash health.sh >/dev/null 2>&1
HEALTH_FILE=/home/brian/health.txt

# Calendar feeds (optional — used by the iCloud Calendar screen)
# Add as many feeds as needed by incrementing the number.
# iCloud: iCloud.com → Calendar → share icon → Copy Link (use https://, not webcal://)
# Outlook: outlook.office365.com → right-click calendar → Share → Get a link → ICS
# Public/curated feeds (Apple holidays, sports, etc.) can also be added directly.
ICAL_1_URL=https://p51-caldav.icloud.com/published/2/your-calendar-url
ICAL_1_LABEL=Brian
ICAL_2_URL=https://p51-caldav.icloud.com/published/2/your-second-calendar-url
ICAL_2_LABEL=Family
ICAL_3_URL=https://calendars.icloud.com/holidays/us_en-us.ics/
ICAL_3_LABEL=US Holidays
ICAL_4_URL=https://outlook.office365.com/owa/calendar/your-calendar-id/calendar.ics
ICAL_4_LABEL=Work
