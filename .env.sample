# YoLink API credentials (optional)
# If omitted, all YoLink features are automatically disabled (no polling, widgets show nothing).
# Get these from: YoLink App → Account → Advanced Settings → Personal Access Credentials
YOLINK_UAID=your_uaid_here
YOLINK_SECRET=your_secret_key_here

# Path to health.sh output file (optional — defaults to /home/brian/health.txt)
# Set up a root cron to refresh it: * * * * * cd /home/brian && bash health.sh >/dev/null 2>&1
HEALTH_FILE=/home/brian/health.txt
